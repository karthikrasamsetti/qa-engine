# Global provider fallback — used when per-tier vars below are not set.
# Accepted values: anthropic | openai
LLM_PROVIDER=anthropic

# API keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Default model names (used when per-tier REASONING_MODEL / FAST_MODEL are not set)
MODEL_REASONING=claude-sonnet-4-6
MODEL_FAST=claude-haiku-4-5-20251001
OPENAI_MODEL_REASONING=gpt-4o
OPENAI_MODEL_FAST=gpt-4o-mini

# --- Per-tier provider/model overrides ------------------------------------
# When set, these override LLM_PROVIDER for that specific tier.
# Omit (or leave blank) to fall back to LLM_PROVIDER + default model names.
#
# Example — Anthropic for reasoning, OpenAI for fast:
#   REASONING_PROVIDER=anthropic
#   REASONING_MODEL=claude-sonnet-4-6
#   FAST_PROVIDER=openai
#   FAST_MODEL=gpt-4o-mini
#
REASONING_PROVIDER=
REASONING_MODEL=
FAST_PROVIDER=
FAST_MODEL=

JIRA_MCP_URL=
TARGET_URL=http://localhost:3000
MAX_REFLECTION_LOOPS=3
MAX_HEAL_ATTEMPTS=3
